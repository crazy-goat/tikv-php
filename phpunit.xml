<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.0/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         testdox="true">
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
            <exclude>tests/Unit/Grpc/GrpcClientTest.php</exclude>
            <exclude>tests/Unit/Batch/GrpcFutureTest.php</exclude>
            <exclude>tests/Unit/RawKv/RawKvBatchTest.php</exclude>
            <exclude>tests/Unit/RawKv/RawKvClientTest.php</exclude>
        </testsuite>
        <testsuite name="Grpc">
            <file>tests/Unit/Grpc/GrpcClientTest.php</file>
            <file>tests/Unit/Batch/GrpcFutureTest.php</file>
            <file>tests/Unit/RawKv/RawKvBatchTest.php</file>
            <file>tests/Unit/RawKv/RawKvClientTest.php</file>
        </testsuite>
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
        <testsuite name="E2E-RawKV">
            <directory>tests/E2E</directory>
            <exclude>tests/E2E/TxnKvE2ETest.php</exclude>
        </testsuite>
        <testsuite name="E2E-TxnKV">
            <file>tests/E2E/TxnKvE2ETest.php</file>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
    <coverage>
        <report>
            <clover outputFile="coverage.xml"/>
            <html outputDirectory="coverage-html"/>
        </report>
    </coverage>
</phpunit>
